{
  "name": "chatcnd",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "backend": "cd backend && node server.js",
    "frontend": "cd frontend && npm start",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "install:all": "cd backend && npm install && cd ../frontend && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
